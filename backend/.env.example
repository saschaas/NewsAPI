# Application
APP_NAME="Stock News API"
APP_VERSION="1.0.0"
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/news.db
SCHEDULER_DB_URL=sqlite:///./data/scheduler.db

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_ANALYSIS=llama3.1
OLLAMA_MODEL_NER=llama3.1
OLLAMA_MODEL_WHISPER=whisper
OLLAMA_TIMEOUT=300

# Processing
MAX_CONCURRENT_FETCHES=3
DATA_RETENTION_DAYS=30
AUTO_DISABLE_THRESHOLD=5
GLOBAL_PAUSE=false

# Paths
DOWNLOADS_DIR=./downloads
DATA_DIR=./data

# Scraping / Anti-Bot
# chromium, firefox, or webkit
BROWSER_ENGINE=chromium
STEALTH_ENABLED=true
HUMAN_BEHAVIOR_ENABLED=true
USER_AGENT_ROTATION=true

# Proxy (optional - leave empty to disable)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
# Comma-separated for rotation
PROXY_URLS=

# RSS
RSS_ENABLED=true
RSS_REQUEST_TIMEOUT=30

# Cloudflare Bypass (Tier 1: curl_cffi, Tier 2: nodriver)
CLOUDFLARE_BYPASS_ENABLED=true
NODRIVER_ENABLED=true
NODRIVER_HEADLESS=true
NODRIVER_TIMEOUT=45
CURL_CFFI_IMPERSONATE=chrome131
CF_COOKIE_TTL_SECONDS=900

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
